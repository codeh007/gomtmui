import { cleanup, render, screen, waitFor } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { afterEach, beforeEach, describe, expect, it, vi } from "vitest";

const { mutateAsyncMock, randomUUIDMock, useRpcMutationMock, useRpcQueryMock } = vi.hoisted(() => ({
  mutateAsyncMock: vi.fn(),
  randomUUIDMock: vi.fn(),
  useRpcMutationMock: vi.fn(),
  useRpcQueryMock: vi.fn(),
}));

vi.mock("mtmsdk/supabase/use-sb-query/use-rpc-query", () => ({
  useRpcQuery: useRpcQueryMock,
}));

vi.mock("mtmsdk/supabase/use-sb-query/use-rpc-mutation", () => ({
  useRpcMutation: useRpcMutationMock,
}));

vi.mock("mtxuilib/lib/utils", async () => {
  const actual = await vi.importActual<typeof import("mtxuilib/lib/utils")>("mtxuilib/lib/utils");
  return {
    ...actual,
    randomUUID: randomUUIDMock,
  };
});

import { InstanceAutoBootstrapView } from "./instance-auto-bootstrap-view";

afterEach(() => {
  cleanup();
  vi.clearAllMocks();
  vi.unstubAllGlobals();
});

describe("InstanceAutoBootstrapView", () => {
  beforeEach(() => {
    randomUUIDMock.mockReturnValue("generated-instance-id");

    useRpcQueryMock.mockReturnValue({
      data: [
        {
          id: "node-1",
          name: "Node 1",
          host: "127.0.0.1",
          port: 22,
          username: "root",
        },
      ],
      isLoading: false,
    });

    mutateAsyncMock.mockResolvedValue({
      data: {
        id: "server-1",
      },
    });

    useRpcMutationMock.mockReturnValue({
      isPending: false,
      mutateAsync: mutateAsyncMock,
    });
  });

  it("创建实例时使用统一 randomUUID 结果提交 RPC", async () => {
    const onSuccess = vi.fn();
    const user = userEvent.setup();

    render(<InstanceAutoBootstrapView onCancel={vi.fn()} onSuccess={onSuccess} />);

    const submitButton = screen.getByRole("button", { name: "创建实例" });

    await waitFor(() => {
      if (submitButton.hasAttribute("disabled")) {
        throw new Error("submit button is still disabled");
      }
    });

    await user.click(submitButton);

    await waitFor(() => {
      expect(mutateAsyncMock).toHaveBeenCalledWith({
        p_id: "generated-instance-id",
        p_compute_node_id: "node-1",
      });
    });

    expect(onSuccess).toHaveBeenCalledWith({ id: "server-1" });
    expect(randomUUIDMock).toHaveBeenCalledTimes(1);
  });
});
